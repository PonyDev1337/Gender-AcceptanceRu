<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- Issues-->
    <IssueDef>
        <defName>Transgender</defName>
        <label>Транс*люди</label>
        <iconPath>GenderAcceptance/UI/Issues/Transgender</iconPath>
    </IssueDef>

    <!-- Precepts-->
    <PreceptDef>
        <defName>Transgender_Adored</defName>
        <issue>Transgender</issue>
        <label>восхваляемые</label>
        <description>Уважение к трансгендерам ведет к большему разнообразию и толерантности.</description>
        <impact>Medium</impact>
        <comps>
            <li Class="PreceptComp_SituationalThought">
                <thought>AmountOfTransgender_Liked</thought>
            </li>
            <li Class ="PreceptComp_SituationalThought">
                <thought>PositiveViewOnTransgender</thought>
            </li>
        </comps>
    </PreceptDef>
    
    <PreceptDef>
        <defName>Transgender_Despised</defName>
        <issue>Transgender</issue>
        <label>Презераемые</label>
        <description>В сответсвие с "традиционными ценностями", трансгендеры противоречат традициям нашего сообщества.</description>
        <impact>Medium</impact>
        <comps>
            <li Class="PreceptComp_SituationalThought">
                <thought>AmountOfTransgender_Disliked</thought>
            </li>
            <li Class ="PreceptComp_SituationalThought">
                <thought>NegativeViewOnTransgender</thought>
            </li>
            <li Class="PreceptComp_SituationalThought">
                <thought>Internal_Transphobia</thought>
            </li>
        </comps>
    </PreceptDef>
</Defs>
